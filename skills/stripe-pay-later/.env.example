# Stripe Pay Later - Example Environment Configuration
# Copy this file to .env and fill in your actual Stripe API keys

# REQUIRED: Your Stripe Secret API Key (starts with sk_test_ or sk_live_)
STRIPE_API_KEY=sk_test_your_secret_key_here

# REQUIRED: Your Stripe Publishable Key (starts with pk_test_ or pk_live_)
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# REQUIRED for webhooks: Your Stripe Webhook Signing Secret
STRIPE_WEBHOOK_SECRET=whsec_test_your_webhook_secret_here

# OPTIONAL: Default currency for transactions (default: usd)
STRIPE_CURRENCY=usd

# OPTIONAL: Default return URL after payment (for redirects)
STRIPE_RETURN_URL=https://yourdomain.com/payment-success

# OPTIONAL: Maximum number of retry attempts (default: 3)
STRIPE_MAX_RETRIES=3

# OPTIONAL: Delay between retries in seconds (default: 1)
STRIPE_RETRY_DELAY=1

# OPTIONAL: Port for webhook server (default: 5000)
PORT=5000

# OPTIONAL: Environment indicator (test or production)
ENVIRONMENT=test
